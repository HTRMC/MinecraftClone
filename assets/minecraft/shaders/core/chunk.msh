#version 460
#extension GL_EXT_mesh_shader : require

layout(binding = 0) uniform UniformBufferObject {
    mat4 view;
    mat4 proj;
} ubo;

// Face Buffer structure - separate indices for shared data
struct FaceData {
    uint positionAndFlags;         // x(5) + y(5) + z(5) + isBackFace(1) + lightIndex(16)
    uint blockAndQuad;             // quadIndex(16) + texture(16)
    uint chunkIndex;               // chunk index
};

// Model Buffer structure (112 bytes per quad - std430 layout)
struct ModelData {
    vec4 vertices[4];      // 4×4×f32 vertex positions (64 bytes)
    vec2 uvCoords[4];      // 4×2×f32 UV coordinates (32 bytes)
    vec4 faceNormal;       // 4×f32 face normal (16 bytes)
};

// Light Buffer structure (16 bytes per light entry)
struct LightData {
    uint vertex0;  // ao(5) + skyLight(5) + blockLight(5) + r(5) + g(5) + b(5) + padding(2)
    uint vertex1;  // Same layout for vertex 1
    uint vertex2;  // Same layout for vertex 2  
    uint vertex3;  // Same layout for vertex 3
};

layout(std430, binding = 1) readonly buffer FaceBuffer {
    FaceData faces[];
};

layout(std430, binding = 2) readonly buffer ModelBuffer {
    ModelData models[];
};

layout(std430, binding = 3) readonly buffer LightBuffer {
    LightData lights[];
};

layout(std430, binding = 4) readonly buffer ChunkCoordBuffer {
    ivec4 chunkCoords[];  // ivec3 chunk coordinates + padding
};

layout(local_size_x = 32, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 128, max_primitives = 64) out;

layout(location = 0) out vec3 fragColor[];
layout(location = 1) out vec2 fragUV[];
layout(location = 2) out flat uint fragTextureIndex[];

// Unpack lighting from uint32 format
vec3 unpackLighting(uint packed) {
    // Extract 6 × 5-bit values: ao(5) + skyLight(5) + blockLight(5) + r(5) + g(5) + b(5)
    uint ao = packed & 0x1Fu;
    uint skyLight = (packed >> 5) & 0x1Fu;
    uint blockLight = (packed >> 10) & 0x1Fu;
    uint r = (packed >> 15) & 0x1Fu;
    uint g = (packed >> 20) & 0x1Fu;
    uint b = (packed >> 25) & 0x1Fu;
    
    // Convert 5-bit values to 0-1 range and combine lighting
    float aoFactor = (ao == 0u) ? 1.0 : float(ao) / 31.0;
    float lightLevel = (float(skyLight) + float(blockLight)) / 62.0;
    vec3 color = vec3(float(r), float(g), float(b)) / 31.0;
    
    return color * lightLevel * aoFactor;
}

// Unpack block position from positionAndFlags  
vec3 unpackBlockPosition(uint positionAndFlags) {
    uint x = positionAndFlags & 0x1Fu;
    uint y = (positionAndFlags >> 5) & 0x1Fu;
    uint z = (positionAndFlags >> 10) & 0x1Fu;
    return vec3(float(x), float(y), float(z));
}

// Extract light index from positionAndFlags
uint extractLightIndex(uint positionAndFlags) {
    return (positionAndFlags >> 16) & 0xFFFFu;
}

// Extract quad index from blockAndQuad
uint extractQuadIndex(uint blockAndQuad) {
    return blockAndQuad & 0xFFFFu;
}

// Extract texture index from blockAndQuad
uint extractTextureIndex(uint blockAndQuad) {
    return (blockAndQuad >> 16) & 0xFFFFu;
}

// Extract chunk index from chunkIndex field
uint extractChunkIndex(uint chunkIndex) {
    return chunkIndex;
}

void main() {
    // Thread-safe approach: each thread processes one face independently
    uint faceIndex = gl_WorkGroupID.x * gl_WorkGroupSize.x + gl_LocalInvocationIndex;
    
    // Calculate how many valid faces this workgroup should process
    uint workgroupStartFace = gl_WorkGroupID.x * gl_WorkGroupSize.x;
    uint validFacesInWorkgroup = min(gl_WorkGroupSize.x, faces.length() - workgroupStartFace);
    
    // Only thread 0 sets the output count for the entire workgroup
    if (gl_LocalInvocationIndex == 0u) {
        SetMeshOutputsEXT(validFacesInWorkgroup * 4, validFacesInWorkgroup * 2);
    }
    
    // Early exit if this thread's face index is beyond valid range
    if (gl_LocalInvocationIndex >= validFacesInWorkgroup) {
        return;
    }
    
    // Each valid thread outputs one quad (4 vertices, 2 triangles)
    // Use LOCAL thread index for vertex offset (not face index)
    uint vertexOffset = gl_LocalInvocationIndex * 4;
    uint primitiveOffset = gl_LocalInvocationIndex * 2;
    
    // Extract separate indices for models and lights
    uint quadIdx = extractQuadIndex(faces[faceIndex].blockAndQuad);
    uint textureIdx = extractTextureIndex(faces[faceIndex].blockAndQuad);
    uint lightIdx = extractLightIndex(faces[faceIndex].positionAndFlags);
    uint chunkIdx = extractChunkIndex(faces[faceIndex].chunkIndex);
    
    // Get block position from face buffer (0-15 range)
    vec3 blockPos = unpackBlockPosition(faces[faceIndex].positionAndFlags);
    
    // Get chunk coordinate and convert to world position
    ivec3 chunkCoord = chunkCoords[chunkIdx].xyz;
    vec3 chunkWorldPos = vec3(chunkCoord * 16); // Convert chunk coords to world blocks
    
    // Generate vertices using separate model index
    for (uint i = 0; i < 4; i++) {
        uint vertexIndex = vertexOffset + i;
        vec3 worldPos = chunkWorldPos + blockPos + models[quadIdx].vertices[i].xyz;
        gl_MeshVerticesEXT[vertexIndex].gl_Position = ubo.proj * ubo.view * vec4(worldPos, 1.0);
        
        // Apply lighting from separate light buffer using separate light index
        uint vertexLighting;
        if (i == 0u) vertexLighting = lights[lightIdx].vertex0;
        else if (i == 1u) vertexLighting = lights[lightIdx].vertex1;
        else if (i == 2u) vertexLighting = lights[lightIdx].vertex2;
        else vertexLighting = lights[lightIdx].vertex3;
        
        fragColor[vertexIndex] = unpackLighting(vertexLighting);
        fragUV[vertexIndex] = models[quadIdx].uvCoords[i];
        fragTextureIndex[vertexIndex] = textureIdx;
    }
    
    // Generate triangle indices for quad (two triangles)
    uint baseVertex = vertexOffset;
    gl_PrimitiveTriangleIndicesEXT[primitiveOffset + 0] = uvec3(baseVertex + 0, baseVertex + 1, baseVertex + 2); // First triangle
    gl_PrimitiveTriangleIndicesEXT[primitiveOffset + 1] = uvec3(baseVertex + 0, baseVertex + 2, baseVertex + 3); // Second triangle
}